# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────────
# For local development (host-mapped port from docker compose):
DATABASE_URL=postgresql://tarkify_user:tarkifyPassword@localhost:5439/tarkifyDB
#
# Inside Docker Compose these are overridden automatically:
#   DATABASE_URL=postgresql://${PG_USER}:${PG_PASSWORD}@postgres:5432/${PG_DB}
#
PG_USER=tarkify_user
PG_PASSWORD=tarkifyPassword
PG_DB=tarkifyDB

# ── Razorpay ────────────────────────────────────────────────────────
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production.
# Get test keys at https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ────────────────────────────────────────────────────────────
# Frontend origin for CORS headers
FRONTEND_URL=http://localhost:5173

# ── Storage ─────────────────────────────────────────────────────────
# Path for downloadable product files (relative or absolute)
STORAGE_PATH=./storage

# ── Download Tokens ─────────────────────────────────────────────────
# Token TTL in seconds (default: 600 = 10 minutes, min: 60, max: 86400)
DOWNLOAD_TOKEN_TTL_SECONDS=600
